# =====================================================================
#  Møtetranskripsjonsapp — eksempel-miljø
#  Kopier denne filen til .env og fyll inn dine egne verdier.
#  .env er listet i .gitignore og blir ALDRI committet til Git.
# =====================================================================

# --- Server ----------------------------------------------------------
# Port Express-serveren lytter på. 5000 er default.
PORT=5000

# Sett til "production" for produksjon, "development" for lokal dev.
NODE_ENV=development

# --- Database --------------------------------------------------------
# PostgreSQL connection string. Eksempel for lokal Postgres på Mac:
#   postgresql://<bruker>@localhost:5432/<dbnavn>
# Hvis du har passord:
#   postgresql://<bruker>:<passord>@localhost:5432/<dbnavn>
DATABASE_URL=postgresql://localhost:5432/referat

# --- Sesjon / autentisering ------------------------------------------
# Hemmelig nøkkel for express-session. Genereres av `npm run setup`.
# Erstatt minimum 32 tegn tilfeldig streng.
SESSION_SECRET=skift-meg-til-en-lang-tilfeldig-streng

# Bcrypt-hash av app-passordet ditt. Genereres av `npm run setup`.
# (App-passord = det brukerne taster på login-siden.)
APP_PASSWORD_HASH=

# --- AI-tjenester ----------------------------------------------------
# OpenAI API-nøkkel (kreves). Brukes til GPT-4o for spørsmål/referat,
# og som fallback for transkripsjon hvis HuggingFace ikke er konfigurert.
OPENAI_API_KEY=sk-...

# HuggingFace API-nøkkel (valgfri). Kreves kun hvis du vil bruke
# nb-whisper-endepunktene under for norsk transkripsjon. Hvis tom,
# faller appen tilbake til OpenAI Whisper.
HUGGINGFACE_API_KEY=

# Egne HuggingFace Inference Endpoints for nb-whisper. Hvis disse
# er tomme bruker appen OpenAI Whisper i stedet.
# Eksempel: https://abc123.eu-west-1.aws.endpoints.huggingface.cloud
HF_NB_WHISPER_MEDIUM_URL=
HF_NB_WHISPER_LARGE_URL=
