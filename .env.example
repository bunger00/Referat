# =====================================================================
#  Møtetranskripsjonsapp — eksempel-miljø
#  Kopier denne filen til .env og fyll inn dine egne verdier.
#  .env er listet i .gitignore og blir ALDRI committet til Git.
# =====================================================================

# --- Server ----------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- Supabase (database + auth — samme prosjekt) --------------------
# 1. Opprett et prosjekt på https://supabase.com
# 2. Project Settings → Database → Connection string → URI (port 5432, session mode)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DB_POOL_MAX=10

# Project Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co
# Same value, but Vite needs the VITE_ prefix to expose to the browser bundle.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Project Settings → API → Project API keys → anon (public)
VITE_SUPABASE_ANON_KEY=

# Server validerer JWT-er via JWKS (asymmetrisk ECC) fra
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json — ingen shared secret nødvendig.

# --- AI-tjenester ----------------------------------------------------
# OpenAI API-nøkkel (kreves)
OPENAI_API_KEY=sk-...

# HuggingFace nb-whisper (valgfritt — fall back til OpenAI Whisper hvis tomt)
HUGGINGFACE_API_KEY=
HF_NB_WHISPER_MEDIUM_URL=
HF_NB_WHISPER_LARGE_URL=
